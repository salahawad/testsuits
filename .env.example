# --- Database ---------------------------------------------------------------
POSTGRES_USER=testsuits
POSTGRES_PASSWORD=testsuits
POSTGRES_DB=testsuits
DATABASE_URL=postgresql://testsuits:testsuits@db:5432/testsuits?schema=public

# --- API --------------------------------------------------------------------
# REQUIRED in production. The API refuses to start if NODE_ENV=production and
# this is unset or equal to the default below — JWTs would otherwise be
# forgeable by anyone who reads the repo. Use `openssl rand -hex 48`.
JWT_SECRET=change-me-in-production
API_PORT=4000

# --- Security -------------------------------------------------------------
# Comma-separated list of origins (scheme + host + port) that the browser may
# call the API from. Leave empty in development for auto-reflect. Required in
# production — an empty list denies all cross-origin requests.
# Example: https://qa.example.com,https://qa-staging.example.com
CORS_ALLOWED_ORIGINS=

# Number of reverse-proxy hops to trust for X-Forwarded-For. Set to 1 when
# deployed behind a single proxy (nginx, Caddy, a cloud LB). Without this,
# rate limits treat every request as coming from the proxy's IP and throttle
# all users together.
TRUST_PROXY=

# --- Web --------------------------------------------------------------------
WEB_PORT=5173
# URL the browser uses to reach the API. Must be reachable from the browser,
# not from inside Docker — so use the host machine's address (or localhost).
VITE_API_URL=http://localhost:4000/api

# --- Host ports -------------------------------------------------------------
# Change these if the defaults conflict with something else running on the host.
POSTGRES_HOST_PORT=5434
MINIO_HOST_PORT=9004
MINIO_CONSOLE_HOST_PORT=9005

# --- Object storage (MinIO, S3-compatible) ---------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=testsuits
# URL the browser uses when downloading attachments. Must match the host
# address + MINIO_HOST_PORT above (not the in-Docker address).
S3_PUBLIC_ENDPOINT=http://localhost:9004

# --- Email (Mailpit in dev; swap to Mailgun/SES in prod) --------------------
# In dev, defaults to the local Mailpit container (UI at http://localhost:8025).
# In prod, use your provider's SMTP URL: smtps://user:pass@smtp.mailgun.org:465
SMTP_URL=smtp://mailpit:1025
MAIL_FROM=TestSuits <no-reply@testsuits.local>
APP_URL=http://localhost:5173
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# --- Optional: auto-seed Jira config on first boot --------------------------
# Uncomment and fill in to have the seed attach a JiraConfig to the primary
# company automatically. Omit to configure Jira through the UI instead.
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_USER=you@example.com
# JIRA_TOKEN=your-atlassian-api-token
# JIRA_PROJECT_KEY=PROJ
