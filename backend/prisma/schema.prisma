generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  TESTER
  VIEWER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RunStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum ExecStatus {
  PENDING
  PASSED
  FAILED
  BLOCKED
  SKIPPED
}

enum MilestoneStatus {
  PLANNED
  ACTIVE
  RELEASED
  CANCELLED
}

enum ActivityAction {
  CASE_CREATED
  CASE_UPDATED
  CASE_CLONED
  RUN_CREATED
  RUN_STATUS_CHANGED
  EXECUTION_STATUS_CHANGED
  EXECUTION_ASSIGNED
  COMMENT_ADDED
  JIRA_LINKED
  ATTACHMENT_ADDED
  SHARED_STEP_CREATED
  SHARED_STEP_UPDATED
  WEBHOOK_CONFIGURED
  CUSTOM_FIELDS_UPDATED
}

enum TestLevel {
  SMOKE
  SANITY
  REGRESSION
  ADVANCED
  EXPLORATORY
}

enum Platform {
  WEB
  WINDOWS
  MACOS
  ANDROID
  IOS
}

enum Connectivity {
  ONLINE
  OFFLINE
}

model Company {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  createdAt   DateTime      @default(now())
  users       User[]
  projects    Project[]
  jiraConfig  JiraConfig?
  invites     InviteToken[]
  samlConfig  SamlConfig?
  scimTokens  ScimToken[]
}

model SamlConfig {
  id               String   @id @default(cuid())
  companyId        String   @unique
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entityId         String
  ssoUrl           String
  x509Cert         String
  emailAttribute   String   @default("email")
  nameAttribute    String   @default("name")
  defaultRole      Role     @default(TESTER)
  enabled          Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ScimToken {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name       String
  tokenHash  String   @unique
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
  @@index([companyId])
}

model User {
  id              String               @id @default(cuid())
  email           String               @unique
  name            String
  passwordHash    String
  // Bumped on password change / forced sign-out. Any JWT with iat < this value
  // is treated as revoked, even if not yet expired.
  passwordUpdatedAt DateTime?
  emailVerifiedAt DateTime?
  avatarKey       String?
  failedAttempts  Int                  @default(0)
  lockedUntil     DateTime?
  // Manager-imposed lock — prevents login and API access entirely.
  isLocked        Boolean              @default(false)
  lastLoginAt     DateTime?
  // TOTP two-factor authentication (opt-in per user).
  totpSecret      String?
  totpEnabledAt   DateTime?
  role            Role                 @default(TESTER)
  companyId       String
  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt       DateTime             @default(now())
  runs            TestRun[]
  executions      TestExecution[]
  assignedExecs   TestExecution[]      @relation("ExecAssignee")
  attachments     Attachment[]
  comments        Comment[]
  activities      ActivityLog[]
  apiTokens       ApiToken[]
  sharedSteps     SharedStep[]
  resetTokens     PasswordResetToken[]
  emailVerifyTokens EmailVerificationToken[]
  trustedDevices  TrustedDevice[]
  sentInvites     InviteToken[]        @relation("InvitedBy")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model TrustedDevice {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model InviteToken {
  id           String    @id @default(cuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email        String
  name         String
  role         Role
  tokenHash    String    @unique
  expiresAt    DateTime
  invitedById  String
  invitedBy    User      @relation("InvitedBy", fields: [invitedById], references: [id])
  acceptedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([companyId, email])
}

model ApiToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  tokenHash String   @unique
  lastUsedAt DateTime?
  createdAt DateTime @default(now())
}

model Project {
  id                    String        @id @default(cuid())
  companyId             String
  company               Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  key                   String
  name                  String
  description           String?
  jiraProjectKey        String?
  jiraProjectName       String?
  jiraIssueType         String?
  jiraParentEpicKey     String?
  jiraParentEpicSummary String?
  createdAt             DateTime      @default(now())
  customFields          Json          @default("[]")
  suites                TestSuite[]
  runs                  TestRun[]
  milestones            Milestone[]
  activities            ActivityLog[]
  sharedSteps           SharedStep[]
  webhooks              Webhook[]
  requirementItems      Requirement[]

  @@unique([companyId, key])
}

// First-class requirements. Free-text `TestCase.requirements[]` is still
// supported for back-compat; new workflows should link to Requirement rows
// so the traceability matrix has something to pivot on.
model Requirement {
  id          String     @id @default(cuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  externalRef String
  title       String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  cases       TestCase[] @relation("CaseRequirements")

  @@unique([projectId, externalRef])
  @@index([projectId])
}

// Company-wide Jira credentials + templates. Per-project targeting (which Jira
// project to file bugs into, optional parent epic, issue type) lives on Project.
model JiraConfig {
  id                  String   @id @default(cuid())
  companyId           String   @unique
  company             Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  baseUrl             String
  email               String
  apiToken            String
  defaultIssueType    String   @default("Bug")
  summaryTemplate     String?
  descriptionTemplate String?
  enabled             Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Milestone {
  id          String          @id @default(cuid())
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  status      MilestoneStatus @default(PLANNED)
  dueDate     DateTime?
  createdAt   DateTime        @default(now())
  runs        TestRun[]

  @@unique([projectId, name])
}

model TestSuite {
  id          String      @id @default(cuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      TestSuite?  @relation("SuiteTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    TestSuite[] @relation("SuiteTree")
  name        String
  description String?
  createdAt   DateTime    @default(now())
  cases       TestCase[]
}

model TestCase {
  id               String          @id @default(cuid())
  suiteId          String
  suite            TestSuite       @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  title            String
  preconditions    String?
  priority         Priority        @default(MEDIUM)
  testLevel        TestLevel       @default(REGRESSION)
  tags             String[]        @default([])
  steps            Json            @default("[]")
  estimatedMinutes Int?
  requirements     String[]        @default([])
  customFieldValues Json           @default("{}")
  cloneOfId        String?
  cloneOf          TestCase?       @relation("CaseClone", fields: [cloneOfId], references: [id])
  clones           TestCase[]      @relation("CaseClone")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  executions       TestExecution[]
  attachments      Attachment[]
  comments         Comment[]
  requirementLinks Requirement[]   @relation("CaseRequirements")
  revisions        TestCaseRevision[]
}

model TestCaseRevision {
  id                String   @id @default(cuid())
  caseId            String
  case              TestCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  version           Int
  title             String
  preconditions     String?
  priority          Priority
  testLevel         TestLevel
  tags              String[]
  steps             Json
  estimatedMinutes  Int?
  requirements      String[]
  customFieldValues Json
  authorId          String?
  createdAt         DateTime @default(now())
  @@unique([caseId, version])
  @@index([caseId, createdAt])
}

model TestRun {
  id           String          @id @default(cuid())
  projectId    String
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestoneId  String?
  milestone    Milestone?      @relation(fields: [milestoneId], references: [id])
  name         String
  description  String?
  environment  String?
  platforms    Platform[]
  connectivities Connectivity[]
  locale       String?
  dueDate      DateTime?
  status       RunStatus       @default(IN_PROGRESS)
  createdById  String
  createdBy    User            @relation(fields: [createdById], references: [id])
  createdAt    DateTime        @default(now())
  completedAt  DateTime?
  executions   TestExecution[]
  comments     Comment[]
}

model TestExecution {
  id              String       @id @default(cuid())
  runId           String
  run             TestRun      @relation(fields: [runId], references: [id], onDelete: Cascade)
  caseId          String
  case            TestCase     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  status          ExecStatus   @default(PENDING)
  notes           String?
  failureReason   String?
  actualResult    String?
  durationMinutes Int?
  assigneeId      String?
  assignee        User?        @relation("ExecAssignee", fields: [assigneeId], references: [id])
  jiraIssueKey    String?
  jiraIssueUrl    String?
  executedById    String?
  executedBy      User?        @relation(fields: [executedById], references: [id])
  executedAt      DateTime?
  createdAt       DateTime     @default(now())
  attachments     Attachment[]
  comments        Comment[]

  @@unique([runId, caseId])
}

model Attachment {
  id           String         @id @default(cuid())
  filename     String
  mimeType     String
  size         Int
  storageKey   String         @unique
  caseId       String?
  case         TestCase?      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  executionId  String?
  execution    TestExecution? @relation(fields: [executionId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User           @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime       @default(now())
}

model Comment {
  id          String         @id @default(cuid())
  body        String
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  caseId      String?
  case        TestCase?      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  executionId String?
  execution   TestExecution? @relation(fields: [executionId], references: [id], onDelete: Cascade)
  runId       String?
  run         TestRun?       @relation(fields: [runId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
}

model ActivityLog {
  id         String         @id @default(cuid())
  projectId  String
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?          @relation(fields: [userId], references: [id])
  action     ActivityAction
  entityType String
  entityId   String
  payload    Json?
  createdAt  DateTime       @default(now())

  @@index([projectId, createdAt])
  @@index([entityType, entityId])
}

model SharedStep {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  action      String
  expected    String
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
}

model Webhook {
  id         String            @id @default(cuid())
  projectId  String
  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url        String
  secret     String?
  events     String[]          @default([])
  active     Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  deliveries WebhookDelivery[]

  @@index([projectId])
}

model WebhookDelivery {
  id          String   @id @default(cuid())
  webhookId   String
  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event       String
  status      Int?
  error       String?
  attemptedAt DateTime @default(now())

  @@index([webhookId, attemptedAt])
}
